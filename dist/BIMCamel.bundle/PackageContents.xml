  <CompanyDetails Name="BIMCamel" Url="https://www.bimcamel.com" />

  <!-- One managed DLL serves every supported release (Navisworks supplies the API of the running
       version). All components point at the single Contents\BIMCamel.dll. -->

  <!-- Navisworks 2026 -->
